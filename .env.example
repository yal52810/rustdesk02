# RustDesk 部署环境变量
# 使用方法: cp .env.example .env 然后修改为实际值

# 域名 (必填)
DOMAIN=api.seset.xyz

# ============================================
# RustDesk Ed25519 密钥 (ID_KEY)
# ============================================
# ⚠️ 必须是完整的 64 字节 Ed25519 私钥 (base64 编码, 约 88 字符)
# 或设为 '_' 让 hbbs 自动生成密钥对到 /data/id_ed25519
#
# ❌ 错误示例 (32字节, 会导致 sk=None, 客户端无法连接):
#   ID_KEY=egwxkaHGAM4MnitF1eP56rJWTAwIUrJCNeCXaArbCrc=
#
# ✅ 正确示例 (64字节私钥):
#   ID_KEY=n8UaPDnEqNbpQhRRLtIjhQn08/gwpvw48I0SHqAAHjZVOQ7i+ZNpXGA0lt3CoV+eZvcPNAPi+WyAZtNIBtRTqw==
#
# ✅ 或让 hbbs 自动管理 (推荐首次部署):
#   ID_KEY=_
#
# 获取方法: docker exec rustdesk-hbbs cat /data/id_ed25519
# ============================================
ID_KEY=_

# RELAY_KEY 一般不需要设置, hbbr 会从共享 volume 读取 /data/id_ed25519
RELAY_KEY=

# Cloudflare API (acme.sh 证书自动续期)
CF_Token=your-cloudflare-api-token-here
CF_Account_ID=your-cloudflare-account-id-here
