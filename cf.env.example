# Cloudflare DNS API credentials for acme.sh DNS-01 challenge
#
# How to get:
#   1. Go to https://dash.cloudflare.com/profile/api-tokens
#   2. Create API Token → "Edit zone DNS" template
#      Zone Resources: Include → Specific zone → frptest.f11.yoga
#   3. Copy the token below
#   4. Copy your Account ID from CF dashboard Overview page
#
# Usage:
#   cp cf.env.example cf.env
#   # Edit cf.env with your real credentials
#   source cf.env && ./init-certs.sh

CF_Token=your-cloudflare-api-token-here
CF_Account_ID=your-cloudflare-account-id-here
