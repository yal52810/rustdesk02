# Cloudflare DNS API credentials for acme.sh DNS-01 challenge
#
# How to get:
#   1. Go to https://dash.cloudflare.com/profile/api-tokens
#   2. Create API Token → "Edit zone DNS" template
#      Zone Resources: Include → Specific zone → your-domain.com
#   3. Copy the token below
#   4. Copy your Account ID from CF dashboard Overview page (right sidebar)
#
# Usage:
#   cp cf.env.example cf.env
#   # Edit cf.env with your real credentials and domain
#   source cf.env && bash init-certs.sh

export DOMAIN=api.seset.xyz
export CF_Token=your-cloudflare-api-token-here
export CF_Account_ID=your-cloudflare-account-id-here
