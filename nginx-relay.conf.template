# ============================================
# RustDesk 中继节点 Nginx — TCP + WSS
# 域名: __DOMAIN__ (启动时自动替换)
# ============================================
# 中继节点只做流量转发，不处理 ID 信令和 API
# ============================================

user nginx;
worker_processes auto;
error_log /var/log/nginx/error.log warn;
pid /var/run/nginx.pid;

events {
    worker_connections 65535;
    use epoll;
    multi_accept on;
}

# ============================================
# Stream 模块 — TCP 中继 (21117)
# ============================================
stream {
    access_log /var/log/nginx/tcp_access.log;

    upstream relay_tcp_backend {
        server relay:21117 max_fails=3 fail_timeout=30s;
    }

    server {
        listen 21117;
        proxy_pass relay_tcp_backend;
        proxy_connect_timeout 10s;
        proxy_timeout 300s;
    }
}

# ============================================
# HTTP 模块 — WSS 中继 (443)
# ============================================
http {
    include /etc/nginx/mime.types;
    default_type application/octet-stream;

    access_log /var/log/nginx/access.log;

    sendfile on;
    tcp_nopush on;
    tcp_nodelay on;
    keepalive_timeout 65;
    client_max_body_size 100m;

    # HTTP → HTTPS
    server {
        listen 80;
        server_name _;
        return 301 https://$host$request_uri;
    }

    server {
        listen 443 ssl;
        http2 on;
        server_name _;

        ssl_certificate     /etc/letsencrypt/live/__DOMAIN__/fullchain.pem;
        ssl_certificate_key /etc/letsencrypt/live/__DOMAIN__/privkey.pem;

        ssl_protocols TLSv1.2 TLSv1.3;
        ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
        ssl_prefer_server_ciphers off;
        ssl_session_cache shared:SSL:10m;

        server_tokens off;

        # WSS 中继 — 客户端通过 wss://relay-xx.seset.xyz/ws/relay 连接
        location /ws/relay {
            proxy_pass http://relay:21119;
            proxy_http_version 1.1;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection "Upgrade";
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_read_timeout 86400s;
            proxy_send_timeout 86400s;
        }

        # 健康检查
        location /health {
            return 200 "ok";
        }
    }
}
